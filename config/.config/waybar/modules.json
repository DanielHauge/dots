{
    "hyprland/workspaces": {
        "active-only": false,
        "all-outputs": false,
        "format": "{}",
        "format-icons": {
            "urgent": "",
            "active": "",
            "default": "."
        }
    },
    "hyprland/window": {
        "rewrite": {
            "(.*) - Brave": "$1",
            "(.*) - Chromium": "$1",
            "(.*) - Brave Search": "$1",
            "(.*) - Outlook": "$1",
            "(.*) Microsoft Teams": "$1"
        },
        "separate-outputs": true
    },
    "custom/appmenu": {
        "format": "Apps",
        "tooltip-format": "Left: Open the application launcher\nRight: Show all keybindings",
        "on-click": "rofi -show drun -replace",
        "on-click-right": "~/.config/ml4w/scripts/keybindings.sh",
        "tooltip": false
    },
    "custom/weather": {
        "exec": "curl -s 'wttr.in/Ballerup?format=1'",
        "interval": 600,
        "format": "{}",
        "tooltip": true
    },
    "custom/cpu": {
        "exec": "~/.config/waybar/spark.sh cpu",
        "return-type": "json",
        "interval": 2,
        "on-click": "kitty btop",
        "escape": false,
        "tooltip": true
    },
    "custom/gpu": {
        "exec": "~/.config/waybar/gpu.sh",
        "return-type": "json",
        "interval": 2,
        "on-click": "kitty btop",
        "escape": false,
        "tooltip": true
    },
    "custom/mem": {
        "exec": "~/.config/waybar/spark.sh mem",
        "return-type": "json",
        "interval": 5,
        "escape": false,
        "on-click": "kitty btop",
        "tooltip": true
    },
    "custom/exit": {
        "format": "´ÇĹ",
        "tooltip-format": "Power off",
        "on-click": "loginctl poweroff",
        "tooltip": true
    },
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "´Çú",
            "unlocked": "´éť"
        }
    },
    "tray": {
        "spacing": 10
    },
    "clock": {
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },
    "custom/system": {
        "format": "ţĹ│",
        "tooltip": false
    },
    "cpu": {
        "format": "/ C {usage}% ",
        "on-click": "kitty htop"
    },
    "memory": {
        "format": "/ M {}% ",
        "on-click": "kitty htop"
    },
    "disk": {
        "interval": 30,
        "format": "D {percentage_used}% ",
        "path": "/",
        "on-click": "kitty htop"
    },
    "hyprland/language": {
        "format": "/ K {short}"
    },
    "group/hardware": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 300,
            "children-class": "not-memory",
            "transition-left-to-right": false
        },
        "modules": [
            "custom/system",
            "disk",
            "cpu",
            "memory",
            "hyprland/language"
        ]
    },
    "network": {
        "format": "{ifname}",
        "format-wifi": "´çź   {signalStrength}%",
        "format-ethernet": "´âü  {ipaddr}",
        "format-disconnected": "Not connected",
        "tooltip-format": " {ifname} via {gwaddri}",
        "tooltip-format-wifi": "´çź   {essid} ({signalStrength}%)",
        "tooltip-format-ethernet": "´âü  {ifname} ({ipaddr}/{cidr})",
        "tooltip-format-disconnected": "Disconnected",
        "max-length": 50,
        "on-click": "kitty nmtui"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}   {capacity}%",
        "format-charging": "´Śž  {capacity}%",
        "format-plugged": "´çŽ  {capacity}%",
        "format-alt": "{icon}  {time}",
        "format-icons": [
            "´ëä ",
            "´ëâ ",
            "´ëé ",
            "´ëü ",
            "´ëÇ "
        ]
    },
    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-bluetooth": "{volume}% {icon}´Őö {format_source}",
        "format-bluetooth-muted": " {icon}´Őö {format_source}",
        "format-muted": "ˇ░Łč muted",
        "format-source": "{volume}% ´ä░",
        "format-source-muted": "´ä▒",
        "format-icons": {
            "headphone": "´Çą",
            "hands-free": "´Çą",
            "headset": "´Çą",
            "phone": "´éĽ",
            "portable": "´éĽ",
            "car": "´ć╣",
            "default": [
                "´ÇŽ",
                "´ÇĘ ",
                "´ÇĘ "
            ]
        },
        "on-click": "pavucontrol",
        "scroll-step": 2
    },
    "bluetooth": {
        "format-disabled": "",
        "format-off": "",
        "interval": 30,
        "on-click": "blueman-manager",
        "format-no-controller": ""
    },
    "user": {
        "format": "{user}",
        "interval": 60,
        "icon": false
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "tooltip": true,
        "format-icons": {
            "activated": "´Ćü",
            "deactivated": "´Çú"
        },
        "on-click-right": "hyprlock"
    }
}
